    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --runInBand",
    "env:dev": "cp .env.development .env && echo 'Switched to development environment (default for local dev)'",
